// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AccountStatus {
  ACTIVE      @map("active")
  DEACTIVATED @map("deactivated")
}

enum UserRole {
  PARENT       @map("parent")
  SCHOOL_ADMIN @map("school_admin")
  MOE_OFFICER  @map("moe_officer")
  MODERATOR    @map("moderator")
}

enum Curriculum {
  LOCAL         @map("local")
  INTERNATIONAL @map("international")
}

enum VerificationStatus {
  VERIFIED @map("verified")
  PENDING  @map("pending")
  REJECTED @map("rejected")
}

enum ReviewCategoryTag {
  SAFETY           @map("safety")
  TEACHING_QUALITY @map("teaching_quality")
  OTHER            @map("other")
}

enum PublisherType {
  MOE          @map("moe")
  SCHOOL_ADMIN @map("school_admin")
}

enum AnnouncementCategory {
  ADMISSIONS @map("admissions")
  POLICY     @map("policy")
  FEE        @map("fee")
  OTHER      @map("other")
}

enum UrgencyLevel {
  NORMAL    @map("normal")
  HIGH      @map("high")
  EMERGENCY @map("emergency")
}

enum InteractionResult {
  OPENED  @map("opened")
  IGNORED @map("ignored")
}

enum ReportTargetType {
  REVIEW @map("review")
  SCHOOL @map("school")
  ANNOUNCEMENT @map("announcement")
}

enum ReportStatus {
  PENDING  @map("pending")
  REVIEWED @map("reviewed")
  RESOLVED @map("resolved")
}

enum NotificationRecipientType {
  PARENT       @map("parent")
  SCHOOL_ADMIN @map("school_admin")
  MOE          @map("moe")
}

model User {
  id          Int           @id @default(autoincrement())
  fullName    String        @map("full_name") @db.VarChar(100)
  email       String        @unique @db.VarChar(100)
  phone       String        @unique @db.VarChar(10)
  password    String        @db.VarChar(255)
  accountStatus AccountStatus @map("account_status")
  role        UserRole
  createdAt   DateTime      @default(now()) @map("created_at")

  // Parent related stuff
  parentProfile            Parent?
  recommendationHistories  RecommendationHistory[]
  comparisons              Comparison[]
  favorites                Favorite[]
  reviews                  Review[]

  // School admin related stuff
  administeredSchools      School[]         @relation("SchoolAdmin")

  // MoE related stuff
  moeOfficerProfile        MoEOfficer?
  moderatorActions         ModeratorAction[] @relation("Moderator")

  // Shared
  announcements            Announcement[]
  reports                  Report[]         @relation("Reporter")
  forumPosts               DiscussionForum[]
  notifications            Notification[]

  @@map("user")
}

model School {
  id                 Int                @id @default(autoincrement()) @map("school_id")
  adminId            Int                @map("admin_id")
  schoolName         String             @map("school_name") @db.VarChar(150)
  address            String             @db.VarChar(255)
  contactEmail       String             @map("contact_email") @db.VarChar(100)
  contactPhone       String             @map("contact_phone") @db.VarChar(10)
  curriculum         Curriculum
  tuitionFee         Decimal            @map("tuition_fee")
  facilities         String?            @db.Text
  verificationStatus VerificationStatus @map("verification_status")
  latitude           Decimal            @db.Decimal(10, 8)
  longitude          Decimal            @db.Decimal(11, 8)

  admin              User               @relation("SchoolAdmin", fields: [adminId], references: [id])
  analytics          Analytics[]
  comparisonSchools  ComparisonSchool[]
  facilityImages     FacilityImage[]
  favorites          Favorite[]
  notifications      Notification[]
  recommendedSchools RecommendedSchool[]
  reviews            Review[]
  updates            SchoolUpdate[]

  @@map("school")
}

model Review {
  id          Int               @id @default(autoincrement()) @map("review_id")
  parentId    Int               @map("parent_id")
  schoolId    Int               @map("school_id")
  rating      Int
  comment     String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at")
  categoryTag ReviewCategoryTag @map("category_tag")

  parent      User              @relation(fields: [parentId], references: [id])
  school      School            @relation(fields: [schoolId], references: [id])

  @@map("review")
}

model Announcement {
  id            Int                  @id @default(autoincrement()) @map("announcement_id")
  publisherId   Int                  @map("publisher_id")
  publisherType PublisherType        @map("publisher_type")
  title         String               @db.VarChar(150)
  content       String               @db.Text
  imgUrl        String?              @map("img_url") @db.VarChar(255)
  createdAt     DateTime             @default(now()) @map("created_at")
  category      AnnouncementCategory
  attachments   String?              @db.VarChar(255)
  datePosted    DateTime             @default(now()) @map("date_posted")
  urgencyLevel  UrgencyLevel         @map("urgency_level")

  publisher     User                 @relation(fields: [publisherId], references: [id])

  @@map("announcement")
}

model Report {
  id         Int               @id @default(autoincrement()) @map("report_id")
  reporterId Int               @map("reporter_id")
  targetType ReportTargetType  @map("target_type")
  targetId   Int               @map("target_id")
  reason     String            @db.VarChar(255)
  status     ReportStatus      @map("status")
  createdAt  DateTime          @default(now()) @map("created_at")

  reporter   User              @relation("Reporter", fields: [reporterId], references: [id])
  actions    ModeratorAction[]

  @@map("report")
}

model Parent {
  userId       Int         @id @map("user_id")
  address      String      @db.VarChar(255)
  latitude     Decimal     @db.Decimal(10, 8)
  longitude    Decimal     @db.Decimal(11, 8)

  user         User        @relation(fields: [userId], references: [id])
  preference   Preference?

  @@map("parent")
}

model FacilityImage {
  id       Int    @id @default(autoincrement()) @map("facility_image_id")
  schoolId Int    @map("school_id")
  imageUrl String @map("image_url") @db.VarChar(255)

  school   School @relation(fields: [schoolId], references: [id])

  @@map("facility_images")
}

model MoEOfficer {
  userId      Int    @id @map("user_id")
  officerRole String @map("officer_role") @db.VarChar(255)

  user        User   @relation(fields: [userId], references: [id])

  @@map("moe_officer")
}

model DiscussionForum {
  id        Int               @id @default(autoincrement()) @map("post_id")
  authorId  Int               @map("author_id")
  content   String            @db.Text
  timestamp DateTime          @default(now())
  threadId  Int?              @map("thread_id")
  isEdited  Boolean           @default(false) @map("is_edited")

  author    User              @relation(fields: [authorId], references: [id])
  thread    DiscussionForum?  @relation("ForumThread", fields: [threadId], references: [id])
  replies   DiscussionForum[] @relation("ForumThread")

  @@map("discussion_forum")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  parentId  Int      @map("parent_id")
  schoolId  Int      @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent    User     @relation(fields: [parentId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([parentId, schoolId])
  @@map("favorite")
}

model RecommendationHistory {
  id                Int                   @id @default(autoincrement()) @map("recommendation_id")
  parentId          Int                   @map("parent_id")
  generatedOn       DateTime              @default(now()) @map("generated_on")
  interactionResult InteractionResult     @map("interaction_result")

  parent            User                  @relation(fields: [parentId], references: [id])
  recommendedSchools RecommendedSchool[]
  preferenceCriteria RecommendationPreferenceCriteria[]

  @@map("recommendation_history")
}

model Comparison {
  id              Int                @id @default(autoincrement()) @map("comparison_id")
  parentId        Int                @map("parent_id")
  metricsUsed     String             @map("metrics_used") @db.Text
  createdAt       DateTime           @default(now()) @map("created_at")

  parent          User               @relation(fields: [parentId], references: [id])
  comparisonSchools ComparisonSchool[]

  @@map("comparison")
}

model Analytics {
  id           Int      @id @default(autoincrement()) @map("data_id")
  schoolId     Int      @map("school_id")
  metricType   String   @map("metric_type") @db.VarChar(255)
  metricValue  Decimal  @map("metric_value")
  academicYear Int      @map("academic_year")
  source       String   @db.VarChar(255)

  school       School   @relation(fields: [schoolId], references: [id])

  @@map("analytics")
}

model ModeratorAction {
  id          Int      @id @default(autoincrement()) @map("action_id")
  moderatorId Int      @map("moderator_id")
  reportId    Int      @map("report_id")
  actionType  String   @map("action_type") @db.VarChar(255)
  notes       String?  @db.Text
  actionDate  DateTime @default(now()) @map("action_date")

  moderator   User     @relation("Moderator", fields: [moderatorId], references: [id])
  report      Report   @relation(fields: [reportId], references: [id])

  @@map("moderator_action")
}

model Notification {
  id              Int      @id @default(autoincrement()) @map("notification_id")
  recipientId     Int      @map("recipient_id")
  recipientType   NotificationRecipientType @map("recipient_type")
  message         String   @db.Text
  sourceReference Int      @map("source_reference")
  isRead          Boolean  @default(false) @map("is_read")
  createdAt       DateTime @default(now()) @map("created_at")

  recipient       User     @relation(fields: [recipientId], references: [id])
  sourceSchool    School   @relation(fields: [sourceReference], references: [id])

  @@map("notification")
}

model SchoolUpdate {
  id          Int      @id @default(autoincrement()) @map("update_id")
  schoolId    Int      @map("school_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  school      School   @relation(fields: [schoolId], references: [id])

  @@map("school_update")
}

model Preference {
  id         Int        @id @default(autoincrement()) @map("preference_id")
  parentId   Int        @unique @map("parent_id")
  minBudget  Decimal    @map("min_budget")
  maxBudget  Decimal    @map("max_budget")
  curriculum Curriculum
  distance   Int

  parent     Parent     @relation(fields: [parentId], references: [userId])

  @@map("preference")
}

model RecommendedSchool {
  id               Int                   @id @default(autoincrement()) @map("recommended_school_id")
  recommendationId Int                   @map("recommendation_id")
  schoolId         Int                   @map("school_id")

  recommendation   RecommendationHistory @relation(fields: [recommendationId], references: [id])
  school           School                @relation(fields: [schoolId], references: [id])

  @@map("recommended_school")
}

model RecommendationPreferenceCriteria {
  id               Int                   @id @default(autoincrement()) @map("preference_criteria_id")
  recommendationId Int                   @map("recommendation_id")
  minBudget        Decimal               @map("min_budget")
  maxBudget        Decimal               @map("max_budget")
  curriculum       Curriculum
  distance         Int

  recommendation   RecommendationHistory @relation(fields: [recommendationId], references: [id])

  @@map("recommendation_preference_criteria")
}

model ComparisonSchool {
  id           Int        @id @default(autoincrement()) @map("comparison_school_id")
  comparisonId Int        @map("comparison_id")
  schoolId     Int        @map("school_id")

  comparison   Comparison @relation(fields: [comparisonId], references: [id])
  school       School     @relation(fields: [schoolId], references: [id])

  @@map("comparison_school")
}


