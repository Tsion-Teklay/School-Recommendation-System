# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Server ---
# Port 5000 is reserved by Windows in some setups — use 5050 if localhost:5000 gives 403.
PORT=5050
NODE_ENV=development
# pino log level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=debug
# Base URL used inside verification / reset links emailed to users.
APP_URL=http://localhost:5050
ML_SERVICE_URL=http://localhost:6006

# --- Auth ---
# Use a long random string. Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# --- Mail (Phase 1: email verification + password reset) ---
# Leave SMTP_URL empty in dev: Nodemailer auto-creates an Ethereal test inbox
# on first send and logs a preview URL you can open in the browser.
# For real delivery, set SMTP_URL to e.g. smtp://user:pass@smtp.gmail.com:587
# or smtp://apikey:KEY@smtp.sendgrid.net:587
SMTP_URL=
MAIL_FROM=no-reply@fidelguide.local

# --- Database (MariaDB / MySQL) ---
# Used by the Prisma MariaDB adapter in `src/config/db.js`.
DATABASE_HOST=127.0.0.1
DATABASE_USER=fidel_guide
DATABASE_PASSWORD=fidel_guide
DATABASE_NAME=fidel_guide_dev

# Used by `prisma migrate` / `prisma studio` (see prisma.config.js).
DATABASE_URL=mysql://fidel_guide:fidel_guide@127.0.0.1:3306/fidel_guide_dev

# --- Uploads (Phase 3: school verification documents) ---
# Local-disk storage for now; Phase 9 swaps the adapter for S3/Backblaze
# without touching call sites. Path is resolved relative to backend/ if not
# absolute. Files served read-only at `/uploads/...`.
UPLOAD_DIR=./uploads
# Per-file cap (bytes). Default 10 MB. Multer rejects oversize uploads with
# 400 VALIDATION_ERROR via the shared upload pipeline.
UPLOAD_MAX_SIZE_BYTES=10485760
