# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Server ---
PORT=5000
NODE_ENV=development
# pino log level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=debug

# --- Auth ---
# Use a long random string. Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# --- Database (MariaDB / MySQL) ---
# Used by the Prisma MariaDB adapter in `src/config/db.js`.
DATABASE_HOST=127.0.0.1
DATABASE_USER=school_rec
DATABASE_PASSWORD=school_rec
DATABASE_NAME=school_rec_dev

# Used by `prisma migrate` / `prisma studio` (see prisma.config.js).
DATABASE_URL=mysql://school_rec:school_rec@127.0.0.1:3306/school_rec_dev
