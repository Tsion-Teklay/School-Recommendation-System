# Flutter Environment Configuration Example
# Copy this file to .env and fill in real values. Never commit .env.

# --- API Configuration ---
# Base URL for the backend API
# Development: http://localhost:5050
# Android Emulator: http://10.0.2.2:5050
# Production: https://api.fidelguide.com
API_BASE_URL=http://localhost:5050

# --- Usage ---
# When running Flutter, use the --dart-define flag:
# flutter run --dart-define=API_BASE_URL=http://localhost:5050
# flutter run -d chrome --dart-define=API_BASE_URL=http://localhost:5050
# flutter build apk --dart-define=API_BASE_URL=https://api.fidelguide.com